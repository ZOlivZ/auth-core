{
  "name": "@zolivz/auth-core",
  "version": "1.0.1",
  "description": "SCIM 2.0 provisioning module + auth helpers for NestJS apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZOlivZ/auth-core.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scim": {
      "types": "./dist/scim/index.d.ts",
      "default": "./dist/scim/index.js"
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED"
}
